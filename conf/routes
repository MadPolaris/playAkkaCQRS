# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET     /                           controllers.HomeController.index()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file                   controllers.Assets.versioned(path="/public", file: Asset)
GET     /balance/:userId                controllers.HomeController.getBalance(userId: String)
POST    /deposit/:userId/:amount        controllers.HomeController.deposit(userId: String, amount: Double)
POST    /withdraw/:userId/:amount       controllers.HomeController.withdraw(userId: String, amount: Double)
POST    /transfer/:fromUserId/:toUserId/:amount   controllers.HomeController.transfer(fromUserId: String, toUserId: String, amount: Double)

# Showcase
GET     /showcase                   controllers.ShowcaseController.index()
GET     /ws/saga/events             controllers.ShowcaseController.socket
POST    /api/saga/inject-fault/:stepId/:behavior  controllers.ShowcaseController.injectFault(stepId: String, behavior: String)
POST    /api/saga/trigger-showcase/:singleStep    controllers.ShowcaseController.triggerShowcase(singleStep: Boolean)
POST    /api/saga/proceed/:transactionId          controllers.ShowcaseController.proceed(transactionId: String)
POST    /api/saga/fix-step/:transactionId/:stepId/:phase controllers.ShowcaseController.fixStep(transactionId: String, stepId: String, phase: String)
POST    /api/saga/resume/:transactionId           controllers.ShowcaseController.resume(transactionId: String)
POST    /api/saga/retry-phase/:transactionId      controllers.ShowcaseController.retryPhase(transactionId: String)
